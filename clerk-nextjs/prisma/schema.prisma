// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Users & Profiles
// ─────────────────────────────────────────────

model User {
  id        String   @id                     // Clerk user ID (e.g. "user_2abc...")
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile          Profile?
  savedScholarships SavedScholarship[]
  matchReviews     MatchReview[]
  pushSubscriptions PushSubscription[]

  @@map("users")
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal details
  firstName       String?
  lastName        String?
  dateOfBirth     DateTime?
  nationality     String?               // ISO 3166-1 alpha-2 code, e.g. "NG"
  countryOfStudy  String?               // ISO 3166-1 alpha-2 code

  // Academic background
  currentDegree   DegreeLevel?          // Undergraduate, Masters, PhD, etc.
  fieldOfStudy    String?
  institution     String?
  gpa             Float?
  gpaScale        Float?    @default(4.0)
  graduationYear  Int?

  // Citizenship / eligibility
  citizenships    String[]              // Array of ISO codes for dual/multiple citizenship

  // Financial
  needsFinancialAid Boolean @default(false)

  // Experience
  workExperienceYears Int?    @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("profiles")
}

enum DegreeLevel {
  HIGH_SCHOOL
  UNDERGRADUATE
  MASTERS
  PHD
  POSTDOCTORAL
  PROFESSIONAL  // JD, MD, MBA, etc.
}

enum ScholarshipType {
  NATIONAL        // e.g. Chevening, DAAD
  UNIVERSITY      // e.g. Uppsala International Scholarship
  DEPARTMENT      // e.g. Biology Dept award
}

enum ApplicationRoute {
  DIRECT          // Apply to scholarship directly
  ADMISSION_FIRST // Must be admitted first
  AUTOMATIC       // Considered automatically on admission
}

// ─────────────────────────────────────────────
// Scholarships
// ─────────────────────────────────────────────

model Scholarship {
  id              String   @id @default(cuid())
  title           String
  description     String   @db.Text
  provider        String                // Organisation or university offering the scholarship
  hostCountry     String?               // ISO code
  hostInstitution String?

  // Eligibility
  eligibleNationalities String[]        // Empty array = open to all
  eligibleDegrees       DegreeLevel[]
  fieldsOfStudy         String[]        // Empty array = all fields
  eligibilityRaw        String?  @db.Text // original scraped text — never lose this
  eligibilityParsed     Json?            // AI-extracted structured eligibility data

  // Award details
  amount          Decimal?  @db.Decimal(12, 2) // Use Decimal to avoid float rounding errors; null = undisclosed
  currency        String   @default("USD")
  coversTuition   Boolean  @default(false)
  coversLiving    Boolean  @default(false)

  // Dates
  openingDate     DateTime?
  deadline        DateTime?
  academicYear    String?               // e.g. "2025/2026"

  // University-specific
  universityName     String?            // e.g. "Uppsala University"
  universityCountry  String?            // ISO country code e.g. "SE"
  programName        String?            // e.g. "MSc Microbiology"
  scholarshipType    ScholarshipType @default(NATIONAL)
  applicationRoute   ApplicationRoute @default(DIRECT)

  // Provenance & crawler metadata
  sourceUrl       String?  @unique      // canonical URL — unique to prevent duplicate entries
  sourceDomain    String?               // e.g. "scholarships.eu" — for domain-level dedup & trust scoring
  verified        Boolean  @default(false)
  verifiedAt      DateTime?
  isActive        Boolean  @default(true)  // soft-delete: false = expired or removed
  lastCrawledAt   DateTime?             // when the crawler last visited this URL
  lastChangedAt   DateTime?             // when the content was last detected as changed
  
  parentProgramId String?               // For grouping (e.g. "Mastercard Foundation")
  
  crawlJobs       CrawlJob[]            // History of crawler jobs that checked this scholarship

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  savedBy         SavedScholarship[]
  matchReviews    MatchReview[]

  @@index([deadline])
  @@index([verified, deadline])
  @@index([isActive, deadline])
  @@index([sourceDomain])
  @@index([universityCountry, scholarshipType])
  @@map("scholarships")
}

// ─────────────────────────────────────────────
// User ↔ Scholarship Interactions
// ─────────────────────────────────────────────

model SavedScholarship {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  scholarshipId String
  scholarship   Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)

  // AI match data (copied at save time so stale rescores don't mutate history)
  matchScore      Float?          // 0.0–1.0
  matchBreakdown  Json?           // per-criterion pass/fail from the matching engine

  // Deadline reminder preferences
  reminder30d     Boolean   @default(true)
  reminder7d      Boolean   @default(true)
  reminder1d      Boolean   @default(true)
  reminderEmail   String?   // email address to send reminders to

  // Engagement tracking
  sourceVisited   Boolean   @default(false) // true once user clicks through to source URL

  savedAt         DateTime  @default(now())

  @@unique([userId, scholarshipId])
  @@index([userId])
  @@map("saved_scholarships")
}

model MatchReview {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  scholarshipId String
  scholarship   Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)

  // AI match score (0.0 – 1.0)
  matchScore      Float
  // Structured reasons for a low score — values: nationality|degree|gpa|funding|other
  mismatchReasons String[]
  // User feedback on the match quality
  feedback        MatchFeedback?
  rating          Int?         @db.SmallInt
  // Did the user submit an application?
  applied         Boolean?
  // short inline rating note from the match quality review flow (our spec)
  note            String?
  // legacy field, leave untouched. ignore in all new feature code. consolidate in a future migration.
  notes           String?      @db.Text

  reviewedAt    DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([userId, scholarshipId])
  @@map("match_reviews")
}

enum MatchFeedback {
  RELEVANT
  NOT_RELEVANT
  ALREADY_APPLIED
  APPLIED_AND_WAITING
  WON
}

// ─────────────────────────────────────────────
// Crawler Infrastructure
// ─────────────────────────────────────────────

model CrawlJob {
  id          String      @id @default(cuid())
  url         String
  status      CrawlStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  errorMsg    String?     @db.Text
  itemsFound  Int         @default(0)
  retryCount  Int         @default(0)
  nextRunAt   DateTime?

  // Change tracking for update jobs
  changeDetected  Boolean @default(false)
  changesJson     Json?
  
  scholarshipId   String
  scholarship     Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("crawl_jobs")
}

enum CrawlStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  auth      String
  p256dh    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}
